{
  "name": "deep-dive-devotions-backend",
  "version": "1.0.0",
  "description": "Backend API for Deep Dive Devotions iOS app",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev-local": "ts-node scripts/localApi.ts",
    "sync": "ts-node src/jobs/syncJob.ts",
    "import-csv": "ts-node scripts/importFromCsv.ts",
    "verify-content": "ts-node scripts/verifyContent.ts",
    "migrate-thumbnails": "ts-node scripts/migrateThumbnails.ts",
    "upload-thumbnails": "ts-node scripts/uploadThumbnails.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.13.0",
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "google-auth-library": "^9.14.0",
    "googleapis": "^140.0.0",
    "helmet": "^7.1.0",
    "jose": "^5.6.3",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
