# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google APIs
# Base64-encoded contents of your service account JSON file
# Command to encode: base64 -i service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=eyJ0...

# Google Sheet ID (from the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEETS_ID=1ABC123...

# Google Cloud Storage
GCS_BUCKET=deep-dive-podcast-assets

# Google Drive folder ID for Thumbnails (from Drive URL)
DRIVE_THUMBNAILS_FOLDER_ID=1ABC123...

# App Store Server API (for subscription validation)
# From App Store Connect > Users and Access > Integrations > In-App Purchase
APP_STORE_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APP_STORE_KEY_ID=XXXXXXXXXX
# Base64-encoded .p8 private key file
# Command: base64 -i AuthKey_XXXXXXXXXX.p8 | tr -d '\n'
APP_STORE_PRIVATE_KEY_BASE64=LS0t...

# App bundle ID
APP_BUNDLE_ID=com.deepdivedevotions

# Internal sync secret (random string, also set in Google Cloud Scheduler)
SYNC_SECRET=change-this-to-a-long-random-string

# Server
PORT=3000
NODE_ENV=development

# Local audio streaming (used by /v1/media/audio/:episodeNumber and CSV import audio_url generation)
AUDIO_EPISODES_PATH=/absolute/path/to/Edited Audio/Episodes
AUDIO_STREAM_BASE_URL=http://localhost:3000
